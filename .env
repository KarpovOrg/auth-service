AUTH_CONFIG__APP__APP_NAME=auth-service
AUTH_CONFIG__APP__DEBUG=1
AUTH_CONFIG__APP__HOST=0.0.0.0
AUTH_CONFIG__APP__PORT=8000

AUTH_CONFIG__JWT__SECRET_KEY=fea822c8d7e0e657ba4a23747b98abad1997dbee040dbf82618f39ffe0414c8e
AUTH_CONFIG__JWT__ALGORITHM=HS256
AUTH_CONFIG__JWT__ACCESS_TOKEN_EXPIRES=10
AUTH_CONFIG__JWT__REFRESH_TOKEN_EXPIRES=30
AUTH_CONFIG__JWT__ACCESS_TOKEN_COOKIE_KEY=access_token
AUTH_CONFIG__JWT__REFRESH_TOKEN_COOKIE_KEY=refresh_token

# PostgreSQL — локально (docker-compose.yml поднимает postgres на localhost:5432)
AUTH_CONFIG__DB__URL=postgresql+asyncpg://postgres:postgres@localhost:5432/auth_service
AUTH_CONFIG__DB__ECHO=1

AUTH_CONFIG__REDIS__URL=redis://localhost:6379/0
AUTH_CONFIG__REDIS__MAX_CONNECTIONS=10

AUTH_CONFIG__OTP__RESEND_INTERVAL=60
AUTH_CONFIG__OTP__MAX_PER_WINDOW=5
AUTH_CONFIG__OTP__WINDOW_SECONDS=3600
AUTH_CONFIG__OTP__TTL_SECONDS=300

AUTH_CONFIG__HTTPX__MAX_CONCURRENCY=50
AUTH_CONFIG__HTTPX__MAX_CONNECTIONS=100
AUTH_CONFIG__HTTPX__MAX_KEEPALIVE=20
AUTH_CONFIG__HTTPX__TIMEOUT_CONNECT=5.0
AUTH_CONFIG__HTTPX__TIMEOUT_READ=5.0
AUTH_CONFIG__HTTPX__TIMEOUT_WRITE=5.0
AUTH_CONFIG__HTTPX__TIMEOUT_POOL=5.0

